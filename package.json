{
  "name": "clawn-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://your-username.github.io/sevamedHMS",
  "proxy": "http://localhost:5000",
  "scripts": {
    "dev": "node -e \"if (!require('fs').existsSync('node_modules')) { console.log('📦 Installing dependencies...'); require('child_process').execSync('npm install', { stdio: 'inherit' }); }\" && node -e \"try { require('child_process').execSync('npx --no vite --version', { stdio: 'ignore' }); } catch (e) { console.log('⚙️ Installing vite...'); require('child_process').execSync('npm install vite', { stdio: 'inherit' }); }\" && echo '🚀 Starting dev server...' && npx vite",
    "dev:full": "concurrently \"cd backend; npm run dev\" \"npm run dev\"",
    "server": "cd backend; npm run dev",
    "client": "npm run dev",
    "start": "npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "start:nocheck": "DISABLE_ESLINT_PLUGIN=true ESLINT_NO_DEV_ERRORS=true TSC_COMPILE_ON_ERROR=true CI=false vite",
    "build:nocheck": "DISABLE_ESLINT_PLUGIN=true ESLINT_NO_DEV_ERRORS=true TSC_COMPILE_ON_ERROR=true vite build",
    "test": "react-scripts test",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy-frontend": "node deploy-frontend/deploy.js",
    "check": "vite --version && echo '✅ Dependencies verified successfully!'",
    "postinstall": "npm run check && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-form": "^0.1.8",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.89.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "fs-extra": "^11.3.2",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.544.0",
    "node-fetch": "^3.3.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-day-picker": "^9.10.0",
    "react-dom": "^19.1.1",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^5.4.21"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
