{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    // ✅ Corrected base path for client-side code
    "baseUrl": "./client/src",
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["../backend/database/*"]
    },

    // ✅ Developer-friendly lenient checks
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "allowUnreachableCode": true,
    "allowUnusedLabels": true
  },

  // ✅ Include your main source, type declarations, and vite-env
  "include": [
    "client/src",
    "client/src/types/**/*",
    "vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
